			function loadGeneralSituation(data){
				var equipmentTotal=0,equipmentWarn=0;
				//中继器
				var totalCount=0,warnCount=0;
				if(data!=null&&data.totalCount!=null)
					totalCount=data.totalCount.中继器;
				if(data!=null&&data.warnCount!=null)
					warnCount=data.warnCount.中继器;
				document.getElementById("gatewayCount").innerHTML = (totalCount==null?0:totalCount)+"<a href='javaScript:warningInfoShow(\"中继器\")'><span>("+(warnCount==null?0:warnCount)+")</span></a>";
				
				//电表
				totalCount=0,warnCount=0;
				if(data!=null&&data.totalCount!=null)
					totalCount=data.totalCount.电表;
				if(data!=null&&data.warnCount!=null)
					warnCount=data.warnCount.电表;
				document.getElementById("electricMeterCount").innerHTML = (totalCount==null?0:totalCount)+"<a href='javaScript:warningInfoShow(\"电表\")'><span>("+(warnCount==null?0:warnCount)+")</span></a>";
				equipmentTotal=equipmentTotal+(totalCount==null?0:totalCount);
				equipmentWarn=equipmentWarn+(warnCount==null?0:warnCount);
				
				//水表
				totalCount=0,warnCount=0;
				if(data!=null&&data.totalCount!=null)
					totalCount=data.totalCount.水表;
				if(data!=null&&data.warnCount!=null)
					warnCount=data.warnCount.水表;
				document.getElementById("waterMeterCount").innerHTML = (totalCount==null?0:totalCount)+"<a href='javaScript:warningInfoShow(\"水表\")'><span>("+(warnCount==null?0:warnCount)+")</span></a>";
				equipmentTotal=equipmentTotal+(totalCount==null?0:totalCount);
				equipmentWarn=equipmentWarn+(warnCount==null?0:warnCount);
				
				//冷热量表
				totalCount=0,warnCount=0;
				if(data!=null&&data.totalCount!=null)
					totalCount=data.totalCount.冷热量表;
				if(data!=null&&data.warnCount!=null)
					warnCount=data.warnCount.冷热量表;
				document.getElementById("coldHeatMeterCount").innerHTML = (totalCount==null?0:totalCount)+"<a href='javaScript:warningInfoShow(\"冷热量表\")'><span>("+(warnCount==null?0:warnCount)+")</span></a>";
				equipmentTotal=equipmentTotal+(totalCount==null?0:totalCount);
				equipmentWarn=equipmentWarn+(warnCount==null?0:warnCount);
				
				//温控器
				totalCount=0,warnCount=0;
				if(data!=null&&data.totalCount!=null)
					totalCount=data.totalCount.温控器;
				if(data!=null&&data.warnCount!=null)
					warnCount=data.warnCount.温控器;
				document.getElementById("thermostatCount").innerHTML = (totalCount==null?0:totalCount)+"<a href='javaScript:warningInfoShow(\"温控器\")'><span>("+(warnCount==null?0:warnCount)+")</span></a>";
				equipmentTotal=equipmentTotal+(totalCount==null?0:totalCount);
				equipmentWarn=equipmentWarn+(warnCount==null?0:warnCount);
				
				//流量计
				totalCount=0,warnCount=0;
				if(data!=null&&data.totalCount!=null)
					totalCount=data.totalCount.流量计;
				if(data!=null&&data.warnCount!=null)
					warnCount=data.warnCount.流量计;
				document.getElementById("flowMeterCount").innerHTML = (totalCount==null?0:totalCount)+"<a href='javaScript:warningInfoShow(\"流量计\")'><span>("+(warnCount==null?0:warnCount)+")</span></a>";
				equipmentTotal=equipmentTotal+(totalCount==null?0:totalCount);
