		<style type="text/css">
			html, body{
				/*margin:0;padding:0;border:0;width:1710px;height:833px;*/
				margin:0;padding:0;border:0;width:100%;height:100%;
         	}
         	.mini-messagebox-buttons .mini-button{
				width:72px !important;
				color:#fff !important;
			}
			.mini-messagebox-buttons .mini-button:hover{
				color:#4bbbff !important;
			}
