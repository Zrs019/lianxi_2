   "source": [
    "#获取身高体重\n",
    "height=float(input(\"请输入身高(米)\"));\n",
    "weight=float(input(\"请输入体重（千克）\"));\n",
    "#计算BMI\n",
    "bmi=weight/height**2\n",
    "#输出结果\n",
    "if bmi<18.5:\n",
    "    print(\"偏瘦\");\n",
    "elif bmi<24:\n",
    "    print(\" 正常\");\n",
    "elif bmi<28:        \n",
    "    print(\"偏胖\");          \n",
    "else:\n",
    "    print(\"肥胖\");  "
   ]
  }
